# Required

# Your Postgres connection string. The database must have pgvector enabled.
DATABASE_URL="postgresql://retaindb:retaindb@localhost:5432/retaindb"

# Auth (optional)
#
# Leave blank for open access on localhost or a private network.
# Set this if your server is publicly reachable.
# Clients must then send: Authorization: Bearer <your-key>
# RETAINDB_API_KEY="your-secret-key-here"

# Embeddings
#
# If OPENAI_API_KEY is set, OpenAI embeddings are used automatically.
# Otherwise the server falls back to the local embedding path.
OPENAI_API_KEY=""

# Optional embedding model override
# EMBEDDING_MODEL="text-embedding-3-small"

# Memory extraction model
# EXTRACTION_MODEL="gpt-4o-mini"

# Server
PORT=3000
