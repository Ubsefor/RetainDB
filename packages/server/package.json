{
  "name": "@retaindb/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --out-dir dist --dts",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.37.0",
    "@hono/node-server": "^1.13.0",
    "@hono/zod-validator": "^0.4.0",
    "@octokit/rest": "^21.0.0",
    "@prisma/client": "^6.0.0",
    "@xenova/transformers": "^2.17.0",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.0",
    "hono": "^4.7.0",
    "nanoid": "^5.0.0",
    "openai": "^4.77.0",
    "p-queue": "^8.0.0",
    "zod": "^3.24.0",
    "pdf-parse": "^1.1.1",
    "postgres": "^3.4.0",
    "tar": "^7.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prisma": "^6.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
